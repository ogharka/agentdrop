# AgentDrop Environment Variables
# Copy this file to .env and fill in your values
# NEVER share your .env file or commit it to GitHub

# Your wallet private key (the agent wallet)
# Get this from MetaMask: Account Details > Export Private Key
PRIVATE_KEY=your_wallet_private_key_here

# Same key for the agent
AGENT_PRIVATE_KEY=your_wallet_private_key_here

# AgentDrop contract address (you get this after deploying)
CONTRACT_ADDRESS=your_contract_address_after_deploy

# Anthropic API key (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Basescan API key (get from https://basescan.org/apis)
BASESCAN_API_KEY=your_basescan_api_key_here

# Backend port
PORT=3001
